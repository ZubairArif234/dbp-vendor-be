# ─── Server ───────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ─────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017
MONGO_DB_NAME=express_boilerplate

# ─── JWT ──────────────────────────────────────────
JWT_SECRET=super-secret-change-me
JWT_EXPIRES_IN=14d

# ─── CORS ─────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ─── External APIs (examples) ────────────────────
# OPENAI_API_KEY=sk-...
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
